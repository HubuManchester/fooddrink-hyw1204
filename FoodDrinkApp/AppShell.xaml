<?xml version="1.0" encoding="UTF-8" ?>
<Shell
    x:Class="FoodDrinkApp.AppShell"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:local="clr-namespace:FoodDrinkApp"
    Title="NutriBite"
    FlyoutBehavior="Disabled"
    Shell.BackgroundColor="{AppThemeBinding Light=#F2FFF7, Dark=#0D1812}"
    Shell.ForegroundColor="{AppThemeBinding Light=#124A2D, Dark=#D7FFE8}"
    Shell.TitleColor="{AppThemeBinding Light=#124A2D, Dark=#D7FFE8}"
    Shell.UnselectedColor="{AppThemeBinding Light=#6A8D79, Dark=#88A593}"
    Shell.TabBarBackgroundColor="{AppThemeBinding Light=#F2FFF7, Dark=#0D1812}"
    Shell.TabBarForegroundColor="{AppThemeBinding Light=#1E8E5A, Dark=#67E3A3}"
    Shell.TabBarTitleColor="{AppThemeBinding Light=#1E8E5A, Dark=#67E3A3}"
    Shell.TabBarUnselectedColor="{AppThemeBinding Light=#6A8D79, Dark=#88A593}">

    <TabBar>
        <ShellContent
            Title="Foods"
            ContentTemplate="{DataTemplate local:MainPage}"
            Route="MainPage" />

        <ShellContent
            Title="Hardware"
            ContentTemplate="{DataTemplate local:HardwarePage}"
            Route="HardwarePage" />

        <ShellContent
            Title="Settings"
            ContentTemplate="{DataTemplate local:SettingsPage}"
            Route="SettingsPage" />
    </TabBar>

</Shell>