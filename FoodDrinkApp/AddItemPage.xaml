<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="FoodDrinkApp.AddItemPage"
             Title="Add Record">
    <ScrollView>
        <ScrollView.Background>
            <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                <GradientStop Color="{AppThemeBinding Light=#ECFFF4, Dark=#0B1510}" Offset="0.0" />
                <GradientStop Color="{AppThemeBinding Light=#F8FFFB, Dark=#101D16}" Offset="1.0" />
            </LinearGradientBrush>
        </ScrollView.Background>
        <VerticalStackLayout Padding="22" Spacing="16">
            <Border StrokeThickness="0" Padding="18" BackgroundColor="{AppThemeBinding Light=#FFFFFF, Dark=#1A1712}">
                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="24" />
                </Border.StrokeShape>
                <Grid RowDefinitions="Auto,Auto" RowSpacing="6">
                    <Label Text="Add food or drink"
                           FontSize="28"
                           FontAttributes="Bold"
                           TextColor="{AppThemeBinding Light=#124A2D, Dark=#D7FFE8}"
                           SemanticProperties.HeadingLevel="Level1" />
                    <Label Grid.Row="1"
                           Text="Record the full details of a meal worth remembering."
                           FontSize="15"
                           TextColor="{AppThemeBinding Light=#8B6D55, Dark=#D8C4AC}" />
                </Grid>
            </Border>

            <Border StrokeThickness="1"
                    Stroke="{AppThemeBinding Light=#D9EFE2, Dark=#3E3023}"
                    BackgroundColor="{AppThemeBinding Light=#FFFFFA, Dark=#1A1712}"
                    Padding="16">
                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="20" />
                </Border.StrokeShape>
                <VerticalStackLayout Spacing="14">
                    <Label Text="Basic information" FontSize="16" FontAttributes="Bold" TextColor="{AppThemeBinding Light=#15915D, Dark=#7CE5B2}" />
                    <Entry x:Name="NameEntry"
                           Placeholder="Name"
                           SemanticProperties.Hint="Required food or drink name" />
                    <Picker x:Name="CategoryPicker"
                            Title="Category"
                            SemanticProperties.Hint="Required category">
                        <Picker.Items>
                            <x:String>Breakfast</x:String>
                            <x:String>Lunch</x:String>
                            <x:String>Dinner</x:String>
                            <x:String>Snack</x:String>
                            <x:String>Drink</x:String>
                        </Picker.Items>
                    </Picker>
                    <Editor x:Name="DescriptionEditor"
                            Placeholder="Description, ingredients, flavour, or context"
                            AutoSize="TextChanges"
                            HeightRequest="104"
                            SemanticProperties.Hint="Describe this food or drink" />
                </VerticalStackLayout>
            </Border>

            <Border StrokeThickness="1"
                    Stroke="{AppThemeBinding Light=#D9EFE2, Dark=#3E3023}"
                    BackgroundColor="{AppThemeBinding Light=#FFFFFA, Dark=#1A1712}"
                    Padding="16">
                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="20" />
                </Border.StrokeShape>
                <VerticalStackLayout Spacing="14">
                    <Label Text="Nutrition data" FontSize="16" FontAttributes="Bold" TextColor="{AppThemeBinding Light=#2F7A4F, Dark=#8CE6A1}" />
                    <Grid ColumnDefinitions="*,*" ColumnSpacing="12">
                        <Entry x:Name="CaloriesEntry"
                               Placeholder="Calories"
                               Keyboard="Numeric"
                               SemanticProperties.Hint="Required calories as a number" />
                        <Entry x:Name="ProteinEntry"
                               Grid.Column="1"
                               Placeholder="Protein g"
                               Keyboard="Numeric" />
                    </Grid>
                    <Grid ColumnDefinitions="*,*" ColumnSpacing="12">
                        <Entry x:Name="CarbsEntry"
                               Placeholder="Carbs g"
                               Keyboard="Numeric" />
                        <Entry x:Name="FatEntry"
                               Grid.Column="1"
                               Placeholder="Fat g"
                               Keyboard="Numeric" />
                    </Grid>
                    <Entry x:Name="AllergyEntry"
                           Placeholder="Allergy note or dietary restriction"
                           SemanticProperties.Hint="Enter allergy or dietary information" />
                </VerticalStackLayout>
            </Border>

            <Border x:Name="ValidationPanel"
                    IsVisible="False"
                    StrokeThickness="0"
                    BackgroundColor="{AppThemeBinding Light=#EAF9F0, Dark=#23392D}"
                    Padding="14">
                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="18" />
                </Border.StrokeShape>
                <Label x:Name="ValidationLabel"
                       TextColor="{AppThemeBinding Light=#B43820, Dark=#FFB4A6}"
                       FontAttributes="Bold" />
            </Border>

            <Button Text="Save record"
                    FontAttributes="Bold"
                    CornerRadius="22"
                    Padding="18,12"
                    BackgroundColor="#12A86A"
                    TextColor="#FFFFFF"
                    Clicked="OnSaveClicked"
                    SemanticProperties.Hint="Validate and save this record" />
        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
