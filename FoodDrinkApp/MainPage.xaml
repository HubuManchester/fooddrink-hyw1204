<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:models="clr-namespace:FoodDrinkApp.Models"
             x:Class="FoodDrinkApp.MainPage"
             Title="NutriBite">
    <Grid RowDefinitions="Auto,*">
        <Grid.Background>
            <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                <GradientStop Color="{AppThemeBinding Light=#ECFFF4, Dark=#0B1510}" Offset="0.0" />
                <GradientStop Color="{AppThemeBinding Light=#F8FFFB, Dark=#101D16}" Offset="0.45" />
                <GradientStop Color="{AppThemeBinding Light=#E4F8EB, Dark=#132019}" Offset="1.0" />
            </LinearGradientBrush>
        </Grid.Background>

        <Grid Padding="20,10,20,12">
            <Border StrokeThickness="0" Padding="16">
                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="24" />
                </Border.StrokeShape>
                <Border.Background>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                        <GradientStop Color="{AppThemeBinding Light=#0E9F6E, Dark=#0A5A3E}" Offset="0.0" />
                        <GradientStop Color="{AppThemeBinding Light=#23C483, Dark=#157A55}" Offset="0.62" />
                        <GradientStop Color="{AppThemeBinding Light=#6BE0A9, Dark=#1E9B6B}" Offset="1.0" />
                    </LinearGradientBrush>
                </Border.Background>
                <Border.Shadow>
                    <Shadow Brush="#33000000" Offset="0,8" Radius="18" Opacity="0.45" />
                </Border.Shadow>
                <Grid RowDefinitions="Auto,Auto,Auto,Auto" RowSpacing="10">
                    <Label Text="NutriBite"
                           FontSize="26"
                           FontAttributes="Bold"
                           TextColor="#FFFFFF"
                           SemanticProperties.HeadingLevel="Level1" />
                    <Label Grid.Row="1"
                           Text="Track nutrition, flavour, photos, and meal context in one place."
                           FontSize="13"
                           TextColor="#FFF5E8" />
                    <Grid Grid.Row="2" ColumnDefinitions="*,*,*" ColumnSpacing="8" Margin="0,3,0,0">
                        <Border BackgroundColor="#33FFFFFF" StrokeThickness="0" Padding="12,10">
                            <Border.StrokeShape>
                                <RoundRectangle CornerRadius="18" />
                            </Border.StrokeShape>
                            <Label Text="Nutrition" TextColor="#FFFFFF" FontSize="12" FontAttributes="Bold" HorizontalTextAlignment="Center" />
                        </Border>
                        <Border Grid.Column="1" BackgroundColor="#33FFFFFF" StrokeThickness="0" Padding="10,7">
                            <Border.StrokeShape>
                                <RoundRectangle CornerRadius="18" />
                            </Border.StrokeShape>
                            <Label Text="Photos" TextColor="#FFFFFF" FontSize="12" FontAttributes="Bold" HorizontalTextAlignment="Center" />
                        </Border>
                        <Border Grid.Column="2" BackgroundColor="#33FFFFFF" StrokeThickness="0" Padding="10,7">
                            <Border.StrokeShape>
                                <RoundRectangle CornerRadius="18" />
                            </Border.StrokeShape>
                            <Label Text="Voice" TextColor="#FFFFFF" FontSize="12" FontAttributes="Bold" HorizontalTextAlignment="Center" />
                        </Border>
                    </Grid>
                    <Grid Grid.Row="3" ColumnDefinitions="*,Auto" ColumnSpacing="10" Margin="0,6,0,0">
                        <Border StrokeThickness="1"
                                Stroke="#9EE6C3"
                                BackgroundColor="#FFFFFF"
                                Padding="0">
                            <Border.StrokeShape>
                                <RoundRectangle CornerRadius="22" />
                            </Border.StrokeShape>
                            <SearchBar x:Name="SearchFoodBar"
                                       Placeholder="Search foods, drinks, categories, or tags"
                                       HeightRequest="48"
                                       TextChanged="OnSearchTextChanged"
                                       SearchButtonPressed="OnSearchButtonPressed"
                                       TextColor="#3A2518"
                                       PlaceholderColor="#9A7B63"
                                       BackgroundColor="Transparent"
                                       SemanticProperties.Hint="Search the food and drink list" />
                        </Border>
                        <Button Grid.Column="1"
                                Text="Add"
                                CornerRadius="22"
                                Padding="22,0"
                                BackgroundColor="#12A86A"
                                TextColor="#FFFFFF"
                                FontAttributes="Bold"
                                Clicked="OnAddClicked"
                                SemanticProperties.Hint="Add a new food or drink record" />
                    </Grid>
                </Grid>
            </Border>
        </Grid>

        <RefreshView Grid.Row="1" x:Name="FoodRefreshView" Refreshing="OnRefreshing">
            <CollectionView x:Name="FoodCollection"
                            SelectionMode="None"
                            EmptyView="No matching food or drink records."
                            Margin="16,0,16,18">
                <CollectionView.ItemTemplate>
                    <DataTemplate x:DataType="models:FoodItem">
                        <Border StrokeThickness="1"
                                Stroke="{AppThemeBinding Light=#D9EFE2, Dark=#3E3023}"
                                BackgroundColor="{AppThemeBinding Light=#FFFFFF, Dark=#1A1712}"
                                Padding="0"
                                Margin="0,0,0,12">
                            <Border.StrokeShape>
                                <RoundRectangle CornerRadius="28" />
                            </Border.StrokeShape>
                            <Border.Shadow>
                                <Shadow Brush="#22000000" Offset="0,8" Radius="20" Opacity="0.42" />
                            </Border.Shadow>
                            <Grid ColumnDefinitions="0,*">
                                <Grid Grid.Column="1" Padding="14" RowDefinitions="Auto,Auto,Auto,Auto" ColumnDefinitions="*,Auto" RowSpacing="4" ColumnSpacing="10">
                                    <Label Text="{Binding Name}"
                                           FontSize="18"
                                           FontAttributes="Bold"
                                           TextColor="{AppThemeBinding Light=#3A2518, Dark=#FFF2DF}"
                                           SemanticProperties.HeadingLevel="Level2" />
                                    <Border Grid.Column="1"
                                            StrokeThickness="0"
                                            BackgroundColor="{AppThemeBinding Light=#DDF8E8, Dark=#19462E}"
                                            Padding="10,5">
                                        <Border.StrokeShape>
                                            <RoundRectangle CornerRadius="20" />
                                        </Border.StrokeShape>
                                        <Label Text="{Binding CaloriesLabel}"
                                               FontSize="13"
                                               FontAttributes="Bold"
                                               TextColor="{AppThemeBinding Light=#A95517, Dark=#FFD18E}" />
                                    </Border>
                                    <Label Grid.Row="1"
                                           Grid.ColumnSpan="2"
                                           Text="{Binding Description}"
                                           FontSize="13"
                                           TextColor="{AppThemeBinding Light=#6E5A47, Dark=#D8C4AC}"
                                           LineBreakMode="TailTruncation" />
                                    <Label Grid.Row="2"
                                           Grid.ColumnSpan="2"
                                           Text="{Binding MacroSummary}"
                                           FontSize="13"
                                           TextColor="{AppThemeBinding Light=#2F7A4F, Dark=#8CE6A1}" />
                                    <Grid Grid.Row="3" Grid.ColumnSpan="2" ColumnDefinitions="*,Auto" Margin="0,4,0,0">
                                        <Label Text="{Binding Category}"
                                               FontSize="13"
                                               FontAttributes="Bold"
                                               TextColor="{AppThemeBinding Light=#15915D, Dark=#7CE5B2}" />
                                        <Button Grid.Column="1"
                                                Text="Details"
                                                Padding="14,8"
                                                BackgroundColor="{AppThemeBinding Light=#12A86A, Dark=#4FD89A}"
                                                TextColor="{AppThemeBinding Light=#FFFFFF, Dark=#261307}"
                                                CommandParameter="{Binding Id}"
                                                Clicked="OnDetailsClicked"
                                                SemanticProperties.Hint="Open nutrition details" />
                                    </Grid>
                                </Grid>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>
        </RefreshView>
    </Grid>
</ContentPage>
